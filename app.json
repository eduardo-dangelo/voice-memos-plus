{
  "expo": {
    "name": "Voice Memos Plus",
    "slug": "voice-memos-plus",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "voicememosplus",
    "userInterfaceStyle": "automatic",
    "platforms": [
      "ios"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.voicememosplus.app",
      "userInterfaceStyle": "automatic",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Voice Memos Plus needs microphone access to record audio.",
        "NSLocationWhenInUseUsageDescription": "Voice Memos Plus uses your location to name new recordings, like Apple Voice Memos.",
        "ITSAppUsesNonExemptEncryption": false,
        "NSSupportsLiveActivities": true,
        "NSSupportsLiveActivitiesFrequentUpdates": true,
        "UISupportedInterfaceOrientations": [
          "UIInterfaceOrientationPortrait"
        ],
        "UISupportedInterfaceOrientations~ipad": [
          "UIInterfaceOrientationPortrait",
          "UIInterfaceOrientationPortraitUpsideDown",
          "UIInterfaceOrientationLandscapeLeft",
          "UIInterfaceOrientationLandscapeRight"
        ]
      }
    },
    "plugins": [
      "expo-router",
      [
        "react-native-audio-api",
        {
          "iosBackgroundMode": true,
          "iosMicrophonePermission": "Voice Memos Plus needs microphone access to record audio."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Voice Memos Plus uses your location to name new recordings, like Apple Voice Memos."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-widgets",
        {
          "bundleIdentifier": "com.voicememosplus.app.widgets",
          "groupIdentifier": "group.com.voicememosplus.app",
          "enablePushNotifications": false,
          "frequentUpdates": true
        }
      ],
      "./plugins/stripWidgetsPushEntitlement.js"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
